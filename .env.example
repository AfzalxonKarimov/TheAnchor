# Supabase Configuration - Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth Web Client ID - from Google Cloud Console (OAuth 2.0 Web application).
# Must match the "Web client ID" configured in Supabase -> Auth -> Providers -> Google.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id
# Optional native client IDs for iOS/Android builds:
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id

# OpenRouter API key (if using for AI features post-MVP)
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-anthropic-api-key