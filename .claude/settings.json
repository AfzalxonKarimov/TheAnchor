{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git log*)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(npx expo*)",
      "Bash(npx eas*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)"
    ]
  }
}